# Grace Young production Docker Compose env
PROJECT_NAME=Grace Young
ENVIRONMENT=production

# Public origins. Replace with your real domains when Nginx Proxy Manager is ready.
CLIENT_ORIGIN=https://kgraceyoung.com
ADMIN_ORIGIN=https://admin.kgraceyoung.com
API_ORIGIN=https://api.kgraceyoung.com
ALLOWED_ORIGINS=https://kgraceyoung.com,https://www.kgraceyoung.com,https://admin.kgraceyoung.com

# Next.js build-time public URL. Rebuild client/admin after changing this value.
NEXT_PUBLIC_API_URL=https://api.kgraceyoung.com
NEXT_PUBLIC_CLIENT_ORIGIN=https://kgraceyoung.com
NEXT_PUBLIC_ADMIN_ORIGIN=https://admin.kgraceyoung.com
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,fr,es,ko
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# PostgreSQL
POSTGRES_DB=graceyoung
POSTGRES_USER=graceyoung
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+psycopg://graceyoung:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/graceyoung

# Redis / queue
REDIS_URL=redis://redis:6379/0
QUEUE_BROKER_URL=redis://redis:6379/1
QUEUE_RESULT_BACKEND=redis://redis:6379/2

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000
# Public URL that browser can use for uploaded product images.
# For quick test, use http://YOUR_SERVER_IP:19000. For production, proxy storage through HTTPS.
MINIO_PUBLIC_ENDPOINT=http://34.48.83.76:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_BUCKET_PRODUCTS=grace-young-products
MINIO_BUCKET_REELS=grace-young-reels
MINIO_BUCKET_REVIEWS=grace-young-reviews
MINIO_SECURE=false

# Meilisearch
MEILI_MASTER_KEY=CHANGE_ME_STRONG_MEILI_MASTER_KEY
MEILI_URL=http://meilisearch:7700

# Mail
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=no-reply@kgraceyoung.com
MAIL_USERNAME=
MAIL_PASSWORD=

# Auth
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET_64_CHARS_MINIMUM
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Localization / commerce
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,fr,es,ko
DEFAULT_CURRENCY=USD

# Payment placeholders for later phases
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Shipping placeholders for later phases
EASYPOST_API_KEY=
SHIPPO_API_KEY=
