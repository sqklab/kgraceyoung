# Grace Young local development
# Copy to .env at repository root. Backend, frontend client/admin, seed scripts, and Docker Compose read this file.

PROJECT_NAME=Grace Young
ENVIRONMENT=local

# Public origins
CLIENT_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001
API_ORIGIN=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Next.js public env values are derived automatically from the values above by scripts/run-with-root-env.mjs.
# You can override them manually when needed.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLIENT_ORIGIN=http://localhost:3000
NEXT_PUBLIC_ADMIN_ORIGIN=http://localhost:3001
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,fr,es,ko
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graceyoung
POSTGRES_USER=graceyoung
POSTGRES_PASSWORD=graceyoung
DATABASE_URL=postgresql+psycopg://graceyoung:graceyoung@localhost:5432/graceyoung

# Redis / queue
REDIS_URL=redis://localhost:6379/0
QUEUE_BROKER_URL=redis://localhost:6379/1
QUEUE_RESULT_BACKEND=redis://localhost:6379/2

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=https://api.kgraceyoung.com/api/v1/assets
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_PRODUCTS=grace-young-products
MINIO_BUCKET_REELS=grace-young-reels
MINIO_BUCKET_REVIEWS=grace-young-reviews
MINIO_SECURE=false

# Meilisearch
MEILI_MASTER_KEY=graceyoung_dev_master_key
MEILI_URL=http://localhost:7700

# MailHog / email
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=no-reply@graceyoung.local
MAIL_USERNAME=
MAIL_PASSWORD=

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Localization / commerce
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,fr,es,ko
DEFAULT_CURRENCY=USD

# Payment placeholders for later phases
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Shipping placeholders for later phases
EASYPOST_API_KEY=
SHIPPO_API_KEY=
